# AI Employee - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Core Configuration
# ===========================================

# Path to your Obsidian vault (absolute path recommended)
VAULT_PATH=./AI_Employee_Vault

# Run in dry-run mode (log actions without executing)
# Set to 'true' for testing, 'false' for production
DRY_RUN=false

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===========================================
# Watcher Configuration
# ===========================================

# File system watcher check interval (seconds)
CHECK_INTERVAL=5

# Drop folder path (relative to vault or absolute)
DROP_FOLDER=./Drop_Folder

# ===========================================
# Orchestrator Configuration
# ===========================================

# Orchestration cycle interval (seconds)
ORCHESTRATOR_INTERVAL=30

# Maximum Ralph Wiggum iterations before forcing stop
MAX_ITERATIONS=10

# ===========================================
# Future: Gmail Watcher (Silver Tier)
# ===========================================

# Gmail API credentials (OAuth 2.0)
# GMAIL_CLIENT_ID=your_client_id
# GMAIL_CLIENT_SECRET=your_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token

# Gmail check interval (seconds)
# GMAIL_CHECK_INTERVAL=120

# ===========================================
# Future: WhatsApp Watcher (Silver Tier)
# ===========================================

# WhatsApp session path
# WHATSAPP_SESSION_PATH=/path/to/session

# WhatsApp check interval (seconds)
# WHATSAPP_CHECK_INTERVAL=30

# Keywords to flag as urgent
# WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help

# ===========================================
# Future: MCP Servers (Silver/Gold Tier)
# ===========================================

# Email MCP configuration
# EMAIL_MCP_PATH=/path/to/email-mcp
# EMAIL_FROM_ADDRESS=your@email.com

# Browser MCP configuration
# BROWSER_HEADLESS=true

# ===========================================
# Security & Rate Limiting
# ===========================================

# Maximum emails per hour
MAX_EMAILS_PER_HOUR=10

# Maximum payments per day
MAX_PAYMENTS_PER_DAY=5

# Payment approval threshold (auto-approve below this amount)
AUTO_APPROVE_THRESHOLD=50

# Require approval for new payees (true/false)
REQUIRE_APPROVAL_NEW_PAYEES=true

# ===========================================
# Notifications (Future)
# ===========================================

# Email for critical alerts
# ALERT_EMAIL=your@email.com

# Webhook for notifications
# ALERT_WEBHOOK_URL=https://your-webhook.com/alerts
